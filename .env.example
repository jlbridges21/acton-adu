VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Acton PDF Compressor API on Render (full endpoint URL).
# Only used when the user checks "Compress PDF" during export.
VITE_COMPRESS_API_URL=https://acton-pdf-compressor.onrender.com/compress-pdf

# Optional compression settings sent with each compress request (defaults: 12 MB, 300 DPI)
VITE_COMPRESS_MIN_MB=12
VITE_COMPRESS_DPI=300
